# ── 100Bocas Frontend — Quick rebuild ──
FROM node:22-slim

WORKDIR /app

COPY dist/ ./dist/
COPY frontend/ssr-server.mjs ./frontend/
COPY frontend/package.json ./frontend/
COPY frontend/public/ ./frontend/public/

RUN cd frontend && npm install --omit=dev --ignore-scripts 2>&1 | tail -3

EXPOSE 8120
HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
    CMD wget -qO- http://localhost:8120/ || exit 1
CMD ["node", "frontend/ssr-server.mjs"]
